<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.FINTECH" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- AMOLED pure black -->
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <style name="Theme.FINTECH" parent="Base.Theme.FINTECH" />

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Set the splash screen background -->
        <item name="windowSplashScreenBackground">@android:color/black</item>
        <!-- Set an icon or simple text equivalent if we had an icon -->
        <item name="postSplashScreenTheme">@style/Theme.FINTECH</item>
    </style>
</resources>
